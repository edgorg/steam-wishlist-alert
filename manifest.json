{
  "manifest_version": 3,
  "name": "Steam Wishlist Alerts",
  "version": "1.1.0",
  "description": "Get notified when games on your Steam wishlist go on sale or hit your target price",
  "permissions": [
    "storage",
    "alarms",
    "notifications",
    "activeTab",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "https://store.steampowered.com/*",
    "https://steamcommunity.com/*",
    "https://api.steampowered.com/*",
    "https://cdn.akamai.steamstatic.com/*",
    "https://api.isthereanydeal.com/*",
    "https://www.isthereanydeal.com/*",
    "https://api.lemonsqueezy.com/*",
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["https://store.steampowered.com/wishlist/*"],
      "js": ["content/wishlist-importer.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://store.steampowered.com/app/*"],
      "js": ["content/steam-quick-add.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["content/compare-modal.js"],
      "matches": ["<all_urls>"]
    }
  ]
}